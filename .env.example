# ─── Django ───────────────────────────────────────────────────────────────────
SECRET_KEY=your-secret-key-here-change-in-production
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1
DJANGO_SETTINGS_MODULE=config.settings.development

# ─── Database ─────────────────────────────────────────────────────────────────
DATABASE_URL=postgis://agriprofile:agriprofile_dev@localhost:5432/agriprofile_db
DB_PASSWORD=agriprofile_dev

# ─── Redis ────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ─── JWT ──────────────────────────────────────────────────────────────────────
JWT_ACCESS_TOKEN_LIFETIME_MINUTES=60
JWT_REFRESH_TOKEN_LIFETIME_DAYS=7
JWT_FIELD_AGENT_LIFETIME_HOURS=12

# ─── File Storage (Cloudinary) ────────────────────────────────────────────────
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# ─── OpenAgri Services ────────────────────────────────────────────────────────
OPENAGRI_WEATHER_URL=http://weather-service:8010
OPENAGRI_WEATHER_USERNAME=test
OPENAGRI_WEATHER_PASSWORD=test
OPENAGRI_CALENDAR_URL=http://farm-calendar:8002
OPENAGRI_CALENDAR_USERNAME=admin
OPENAGRI_CALENDAR_PASSWORD=admin

# ─── OpenWeatherMap (used by OpenAgri WeatherService) ─────────────────────────
OPENWEATHERMAP_API_KEY=

# ─── Celery ───────────────────────────────────────────────────────────────────
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0

# ─── Frontend ─────────────────────────────────────────────────────────────────
